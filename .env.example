# ballchasing.com API token (REQUIRED)
# Get yours at https://ballchasing.com/upload (signed-in users only)
BALLCHASING_TOKEN=

# Visibility for uploaded replays: public | unlisted | private
# Default: private
BALLCHASING_VISIBILITY=private

# Optional: ballchasing group ID to auto-assign every upload to a group.
# Leave blank to skip group assignment.
BALLCHASING_GROUP=

# Address of the Rocket League Stats API (built into RL itself; see README).
# Default: 127.0.0.1:49123
RLS_TCP_ADDR=127.0.0.1:49123

# Seconds to wait for a manually-saved .replay file after MatchEnded.
# Manual save can take a while if the user lingers on the podium screen.
# Default: 300
WATCH_TIMEOUT_SECS=300

# Set to any non-empty value to skip the GitHub Releases update check on start.
# Default: unset (update check is enabled)
# SKIP_UPDATE=1
